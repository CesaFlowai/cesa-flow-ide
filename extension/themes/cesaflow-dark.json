  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#475569", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#86efac" }
    },
    {
      "name": "Template literal",
      "scope": "string.template",
      "settings": { "foreground": "#6ee7b7" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#fb923c" }
    },
    {
      "name": "Boolean / null / undefined",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#f472b6" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#c084fc", "fontStyle": "italic" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.accessor"],
      "settings": { "foreground": "#94a3b8" }
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function", "meta.function-call.generic"],
      "settings": { "foreground": "#60a5fa" }
    },
    {
      "name": "Class / Type",
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": { "foreground": "#34d399" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other.readwrite"],
      "settings": { "foreground": "#e2e8f0" }
    },
    {
      "name": "Variable — parameter",
      "scope": "variable.parameter",
      "settings": { "foreground": "#fca5a5", "fontStyle": "italic" }
    },
    {
      "name": "Property",
      "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key"],
      "settings": { "foreground": "#93c5fd" }
    },
    {
      "name": "Import / module",
      "scope": ["entity.name.namespace", "support.module", "support.node"],
      "settings": { "foreground": "#34d399" }
    },
    {
      "name": "Tag name",
      "scope": ["entity.name.tag", "meta.tag"],
      "settings": { "foreground": "#f472b6" }
    },
    {
      "name": "Attribute name",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#fb923c" }
    },
    {
      "name": "Decorator",
      "scope": ["punctuation.decorator", "meta.decorator"],
      "settings": { "foreground": "#fbbf24", "fontStyle": "italic" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css", "source.css support.type"],
      "settings": { "foreground": "#60a5fa" }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#86efac" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#64748b" }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": { "foreground": "#f87171", "fontStyle": "underline" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#e2e8f0",
    "variable.readonly": "#93c5fd",
    "parameter": { "foreground": "#fca5a5", "fontStyle": "italic" },
    "function": "#60a5fa",
    "method": "#60a5fa",
    "class": "#34d399",
    "interface": "#34d399",
    "type": "#34d399",
    "namespace": "#34d399",
    "property": "#93c5fd",
    "enumMember": "#fb923c",
    "keyword": { "foreground": "#c084fc", "fontStyle": "italic" },
    "string": "#86efac",
    "number": "#fb923c",
    "regexp": "#6ee7b7",
    "decorator": { "foreground": "#fbbf24", "fontStyle": "italic" },
    "comment": { "foreground": "#475569", "fontStyle": "italic" }
  }
}
