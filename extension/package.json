{
  "name": "orkestra",
  "displayName": "CesaFlow AI",
  "description": "Multi-agent AI coding assistant — Planner → Backend → Frontend → QA, right inside VS Code",
  "version": "0.3.0",
  "publisher": "orkestra-ai",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Other"],
  "keywords": ["ai", "agent", "code generation", "orkestra", "llm"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cesaflow",
          "title": "CesaFlow AI",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "cesaflow": [
        {
          "type": "webview",
          "id": "cesaflow.sidebar",
          "name": "CesaFlow AI"
        }
      ]
    },
    "commands": [
      {
        "command": "orkestra.newRun",
        "title": "Orkestra: New Run",
        "icon": "$(sparkle)"
      },
      {
        "command": "orkestra.openPanel",
        "title": "Orkestra: Open Panel"
      },
      {
        "command": "orkestra.sendSelection",
        "title": "Orkestra: Send Selection as Context"
      },
      {
        "command": "orkestra.configure",
        "title": "Orkestra: Configure API Key"
      },
      {
        "command": "orkestra.refreshRuns",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "orkestra.cancelRun",
        "title": "Cancel Run",
        "icon": "$(debug-stop)"
      },
      {
        "command": "orkestra.downloadRun",
        "title": "Download Files",
        "icon": "$(cloud-download)"
      },
      {
        "command": "orkestra.applyFiles",
        "title": "Apply to Workspace",
        "icon": "$(check)"
      },
      {
        "command": "orkestra.inlineEdit",
        "title": "Orkestra: Edit Selection (Cmd+K)"
      },
      {
        "command": "orkestra.chat",
        "title": "Orkestra: Open Chat (Cmd+L)"
      },
      {
        "command": "orkestra.welcome",
        "title": "CesaFlow: Welcome / Get Started"
      },
      {
        "command": "orkestra.settings",
        "title": "CesaFlow: Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "keybindings": [
      {
        "command": "orkestra.newRun",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o"
      },
      {
        "command": "orkestra.sendSelection",
        "key": "ctrl+shift+alt+o",
        "mac": "cmd+shift+alt+o",
        "when": "editorHasSelection"
      },
      {
        "command": "orkestra.inlineEdit",
        "key": "ctrl+k",
        "mac": "cmd+k",
        "when": "editorTextFocus"
      },
      {
        "command": "orkestra.chat",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus || !editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "orkestra.sendSelection",
          "when": "editorHasSelection",
          "group": "orkestra"
        },
        {
          "command": "orkestra.newRun",
          "group": "orkestra"
        }
      ]
    },
    "configuration": {
      "title": "CesaFlow",
      "properties": {
        "orkestra.apiKey": {
          "type": "string",
          "default": "",
          "description": "CesaFlow AI API key (Groq, OpenAI, Anthropic, Gemini, OpenRouter...)"
        },
        "orkestra.serverUrl": {
          "type": "string",
          "default": "http://localhost:8001",
          "description": "CesaFlow backend URL (kendi sunucun için)"
        },
        "orkestra.autoApplyFiles": {
          "type": "boolean",
          "default": false,
          "description": "Run tamamlandığında dosyaları workspace'e otomatik uygula"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  }
}
